<Window x:Class="MealCraft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealCraft.ViewModels"
        Title="MealCraft"
        Height="680"
        Width="1100"
        MinHeight="600"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <!-- Das ViewModel wird direkt als DataContext gesetzt. -->
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Linke Seite: Suche, Filter, Statistik und Rezeptliste -->
        <Border Grid.Column="0"
                Padding="12"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="6">

            <DockPanel LastChildFill="True">
                <TextBlock Text="Rezepte"
                           FontSize="24"
                           FontWeight="Bold"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,12" />

                <!-- Such- und Filterbereich -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Suche nach Titel" />
                    <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <TextBlock Text="Kategorie filtern" />
                    <ComboBox ItemsSource="{Binding CategoryFilters}"
                              SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                              Margin="0,0,0,8" />

                    <TextBlock Text="Schwierigkeit filtern" />
                    <ComboBox ItemsSource="{Binding DifficultyFilters}"
                              SelectedItem="{Binding SelectedDifficultyFilter, Mode=TwoWay}"
                              Margin="0,0,0,8" />

                    <Button Content="Filter zurücksetzen"
                            Command="{Binding ClearFiltersCommand}"
                            Height="32" />
                </StackPanel>

                <!-- Statistikbereich -->
                <Border DockPanel.Dock="Top"
                        Padding="8"
                        Background="#F5F5F5"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sichtbar: " FontWeight="Bold" />
                            <TextBlock Text="{Binding Stats.TotalVisible}" />
                            <TextBlock Text=" / Gesamt: " FontWeight="Bold" Margin="12,0,0,0" />
                            <TextBlock Text="{Binding Stats.TotalAll}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Kategorie: " FontWeight="Bold" />
                            <TextBlock Text="{Binding Stats.ActiveCategory}" />
                            <TextBlock Text=" | Ø Zeit: " FontWeight="Bold" Margin="12,0,0,0" />
                            <TextBlock Text="{Binding Stats.AvgPrepTime}" />
                            <TextBlock Text=" Min." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Buttons unten -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Button Content="Neues Rezept"
                            Command="{Binding AddRecipeCommand}"
                            Height="34"
                            Margin="0,0,0,8" />

                    <Button Content="Rezept löschen"
                            Command="{Binding DeleteRecipeCommand}"
                            Height="34" />
                </StackPanel>

                <!-- Gefilterte Rezeptliste -->
                <ListBox ItemsSource="{Binding FilteredRecipes}"
                         SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                         DisplayMemberPath="Title" />
            </DockPanel>
        </Border>

        <!-- Rechte Seite: Detailansicht und direkte Bearbeitung -->
        <Border Grid.Column="1"
                Padding="12"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="6"
                Margin="16,0,0,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Rezeptdetails"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Titel" />
                    <TextBox Text="{Binding SelectedRecipe.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10" />

                    <TextBlock Text="Kategorie" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedRecipe.Category, Mode=TwoWay}"
                              Margin="0,0,0,10" />

                    <TextBlock Text="Schwierigkeit" />
                    <ComboBox ItemsSource="{Binding Difficulties}"
                              SelectedItem="{Binding SelectedRecipe.Difficulty, Mode=TwoWay}"
                              Margin="0,0,0,10" />

                    <TextBlock Text="Zubereitungszeit in Minuten" />
                    <TextBox Text="{Binding SelectedRecipe.PreparationTimeMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10" />

                    <TextBlock Text="Zutaten" />
                    <TextBox Text="{Binding SelectedRecipe.Ingredients, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="100"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10" />

                    <TextBlock Text="Zubereitungsschritte" />
                    <TextBox Text="{Binding SelectedRecipe.Steps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="130"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,12" />

                    <Button Content="Eingaben prüfen"
                            Command="{Binding ValidateSelectedRecipeCommand}"
                            Height="34" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
